{
  "name": "@openclaw/raybans-vision",
  "version": "0.1.0",
  "description": "Meta Ray-Bans × OpenClaw — AI-powered smart glasses platform with vision agents",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "openclaw",
    "meta-ray-bans",
    "smart-glasses",
    "vision-ai",
    "inventory",
    "barcode",
    "ocr"
  ],
  "author": "Dorrian Guy",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "sharp": "^0.33.0",
    "csv-stringify": "^6.5.0",
    "exceljs": "^4.4.0",
    "zod": "^3.23.0",
    "uuid": "^10.0.0",
    "better-sqlite3": "^11.0.0",
    "eventemitter3": "^5.0.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "tsx": "^4.19.0",
    "@types/node": "^22.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/uuid": "^10.0.0"
  }
}
