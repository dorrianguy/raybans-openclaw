# ─── Ray-Bans × OpenClaw Backend — Environment Variables ────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── Required API Keys ─────────────────────────────────────────

# OpenAI API key — used for GPT-4o vision analysis
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Deepgram API key — used for speech-to-text (voice commands)
# Get one at: https://console.deepgram.com/
DEEPGRAM_API_KEY=

# Cartesia API key — used for text-to-speech (agent voice responses)
# Get one at: https://play.cartesia.ai/
CARTESIA_API_KEY=

# ─── Server Configuration ──────────────────────────────────────

# Port to listen on (Railway/Fly set this automatically)
PORT=3847

# Environment: 'development' or 'production'
NODE_ENV=development

# Data directory for SQLite database and images
# In Docker/cloud, this is typically /app/data (mapped to a volume)
DATA_DIR=./data

# ─── Optional: CORS ────────────────────────────────────────────

# Comma-separated list of allowed origins for CORS
# Leave empty or '*' to allow all origins (dev mode)
# In production, set to your companion app domain(s)
# Example: https://myapp.com,capacitor://localhost,http://localhost:5173
CORS_ORIGINS=*

# ─── Optional: Authentication ──────────────────────────────────

# Bearer token for API authentication (leave empty to disable)
# When set, all requests must include: Authorization: Bearer <token>
API_AUTH_TOKEN=

# ─── Optional: Rate Limiting ───────────────────────────────────

# Max API requests per minute per IP (0 = disabled)
RATE_LIMIT_RPM=120

# ─── Optional: Logging ─────────────────────────────────────────

# Log level: 'debug', 'info', 'warn', 'error'
LOG_LEVEL=info

# Enable structured JSON logging (recommended for cloud)
LOG_JSON=false

# ─── Optional: OpenClaw Integration ────────────────────────────

# OpenClaw gateway URL (for node bridge integration)
OPENCLAW_GATEWAY_URL=

# OpenClaw gateway token
OPENCLAW_GATEWAY_TOKEN=

# Device ID of the Ray-Ban glasses node
OPENCLAW_DEVICE_ID=
